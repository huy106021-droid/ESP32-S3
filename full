//================ I2S PIN =================
#define I2S_WS   42
#define I2S_SCK  41
#define I2S_SD   39
#define LR_PIN   38
#define I2S_PORT I2S_NUM_0

#define bufferLen 256
int16_t sBuffer[bufferLen];

//================ STREAM =================
#define PART_BOUNDARY "123456789000000000000987654321"

static const char* STREAM_CONTENT_TYPE =
"multipart/x-mixed-replace;boundary=" PART_BOUNDARY;

static const char* STREAM_BOUNDARY = "\r\n--" PART_BOUNDARY "\r\n";

static const char* STREAM_PART =
"Content-Type: image/jpeg\r\nContent-Length: %u\r\n\r\n";

//================ CAMERA STREAM =================
esp_err_t stream_handler(httpd_req_t *req){
    camera_fb_t * fb = NULL;
    char part_buf[64];

    httpd_resp_set_type(req, STREAM_CONTENT_TYPE);

    while(httpd_req_to_sockfd(req) >= 0){

        fb = esp_camera_fb_get();
        if (!fb) break;

        httpd_resp_send_chunk(req, STREAM_BOUNDARY, strlen(STREAM_BOUNDARY));

        size_t hlen = snprintf(part_buf, 64, STREAM_PART, fb->len);
        httpd_resp_send_chunk(req, part_buf, hlen);

        httpd_resp_send_chunk(req, (const char *)fb->buf, fb->len);

        esp_camera_fb_return(fb);

        vTaskDelay(200 / portTICK_PERIOD_MS); // 🔥 chống FB-OVF
    }

    if(fb) esp_camera_fb_return(fb);
    return ESP_OK;
}

//================ AUDIO STREAM =================
esp_err_t audio_handler(httpd_req_t *req){

    httpd_resp_set_type(req, "audio/wav");

    uint8_t wavHeader[44] = {
    'R','I','F','F',0,0,0,0,'W','A','V','E',
    'f','m','t',' ',16,0,0,0,1,0,1,0,
    0x80,0x3E,0,0,   // 🔥 16000 Hz
    0x00,0x7D,0,0,
    2,0,16,0,
    'd','a','t','a',0,0,0,0
};

    httpd_resp_send_chunk(req, (const char*)wavHeader, 44);

    while(httpd_req_to_sockfd(req) >= 0){

        size_t bytesRead = 0;

        if(i2s_read(I2S_PORT, sBuffer, sizeof(sBuffer), &bytesRead, portMAX_DELAY) == ESP_OK){
            if(bytesRead > 0){
                httpd_resp_send_chunk(req, (const char*)sBuffer, bytesRead);
            }
        }

        vTaskDelay(2);
    }

    return ESP_OK;
}

//================ WEB =================
esp_err_t index_handler(httpd_req_t *req){
    const char* html =
    "<html><body style='text-align:center'>"
    "<h2>ESP32-S3 CAM + AUDIO</h2>"
    "<img src='/stream'><br><br>"
    "<audio controls autoplay muted>"
    "<source src='/audio' type='audio/wav'>"
    "</audio>"
    "</body></html>";

    httpd_resp_send(req, html, strlen(html));
    return ESP_OK;
}

//================ I2S =================
void i2s_init(){

    pinMode(LR_PIN, OUTPUT);

    digitalWrite(LR_PIN, LOW);

    i2s_config_t config;
    memset(&config, 0, sizeof(config));

    config.mode = (i2s_mode_t)(I2S_MODE_MASTER | I2S_MODE_RX);

    // 🔥 QUAN TRỌNG NHẤT
    config.sample_rate = 16000;

    config.bits_per_sample = I2S_BITS_PER_SAMPLE_16BIT;

    config.channel_format = I2S_CHANNEL_FMT_ONLY_LEFT;

    config.communication_format = I2S_COMM_FORMAT_I2S;

    config.intr_alloc_flags = 0;
    config.dma_buf_count = 8;     // 🔥 tăng buffer cho audio
    config.dma_buf_len = 512;

    config.use_apll = false;
    config.tx_desc_auto_clear = false;

    // 🔥 FIX LỖI S3
    config.fixed_mclk = -1;

    i2s_pin_config_t pin_config;
    pin_config.bck_io_num = I2S_SCK;
    pin_config.ws_io_num = I2S_WS;
    pin_config.data_out_num = -1;
    pin_config.data_in_num = I2S_SD;
    pin_config.mck_io_num = I2S_PIN_NO_CHANGE;

    i2s_driver_install(I2S_PORT, &config, 0, NULL);
    i2s_set_pin(I2S_PORT, &pin_config);

    // 🔥 set clock lại cho chắc
    i2s_set_clk(I2S_PORT, 16000, I2S_BITS_PER_SAMPLE_16BIT, I2S_CHANNEL_MONO);

    i2s_zero_dma_buffer(I2S_PORT);
    i2s_start(I2S_PORT);
}

//================ SERVER =================
void startServer(){
    httpd_config_t config = HTTPD_DEFAULT_CONFIG();
    config.lru_purge_enable = true;

    httpd_handle_t server = NULL;

    if(httpd_start(&server, &config) == ESP_OK){

        httpd_uri_t index_uri = { "/", HTTP_GET, index_handler };
        httpd_register_uri_handler(server, &index_uri);

        httpd_uri_t stream_uri = { "/stream", HTTP_GET, stream_handler };
        httpd_register_uri_handler(server, &stream_uri);

        httpd_uri_t audio_uri = { "/audio", HTTP_GET, audio_handler };
        httpd_register_uri_handler(server, &audio_uri);
    }
}

//================ SETUP =================
void setup(){
    Serial.begin(115200);

    camera_config_t config;
    config.ledc_channel = LEDC_CHANNEL_0;
    config.ledc_timer   = LEDC_TIMER_0;

    config.pin_d0 = Y2_GPIO_NUM;
    config.pin_d1 = Y3_GPIO_NUM;
    config.pin_d2 = Y4_GPIO_NUM;
    config.pin_d3 = Y5_GPIO_NUM;
    config.pin_d4 = Y6_GPIO_NUM;
    config.pin_d5 = Y7_GPIO_NUM;
    config.pin_d6 = Y8_GPIO_NUM;
    config.pin_d7 = Y9_GPIO_NUM;

    config.pin_xclk = XCLK_GPIO_NUM;
    config.pin_pclk = PCLK_GPIO_NUM;
    config.pin_vsync = VSYNC_GPIO_NUM;
    config.pin_href = HREF_GPIO_NUM;

    config.pin_sscb_sda = SIOD_GPIO_NUM;
    config.pin_sscb_scl = SIOC_GPIO_NUM;

    config.pin_pwdn  = PWDN_GPIO_NUM;
    config.pin_reset = RESET_GPIO_NUM;

    config.xclk_freq_hz = 10000000;
    config.pixel_format = PIXFORMAT_JPEG;

    config.frame_size   = FRAMESIZE_QQVGA;
    config.jpeg_quality = 30;
    config.fb_count     = 1;
    config.grab_mode    = CAMERA_GRAB_LATEST;
    config.fb_location  = CAMERA_FB_IN_PSRAM;

    if(esp_camera_init(&config) != ESP_OK){
        Serial.println("Camera FAIL");
        return;
    }

    // reset buffer
    esp_camera_fb_return(esp_camera_fb_get());

    WiFi.begin(ssid, pass);
    WiFi.setSleep(false);

    while(WiFi.status() != WL_CONNECTED){
        delay(500);
        Serial.print(".");
    }

    Serial.println("\nIP:");
    Serial.println(WiFi.localIP());

    i2s_init();
    startServer();
}

